{
  "name": "policlinico-backend",
  "version": "1.0.0",
  "description": "Backend API para sistema de gestión de citas médicas (MongoDB)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "dev:clean": "rm -rf dist node_modules/.cache && nodemon --exec ts-node src/index.ts",
    "seed": "ts-node src/config/seed.ts",
    "seed:examenes": "ts-node src/config/seedExamenes.ts",
    "seed:ordenes": "ts-node src/config/seedOrdenes.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "keywords": [
    "api",
    "policlinico",
    "mongodb",
    "express"
  ],
  "author": "Victor Rodríguez",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.19.1",
    "multer": "^2.1.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.18.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.7.2",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.5",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
